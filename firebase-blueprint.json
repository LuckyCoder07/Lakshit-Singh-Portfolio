{
  "entities": {
    "Message": {
      "title": "Message",
      "description": "A chat message in the AI assistant conversation",
      "type": "object",
      "properties": {
        "text": { "type": "string", "description": "The content of the message" },
        "sender": { "type": "string", "enum": ["user", "ai"], "description": "Who sent the message" },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent" },
        "userId": { "type": "string", "description": "The UID of the user" }
      },
      "required": ["text", "sender", "timestamp", "userId"]
    },
    "ContactSubmission": {
      "title": "Contact Submission",
      "description": "A message sent via the contact form",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "message": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "userId": { "type": "string" }
      },
      "required": ["name", "email", "message", "timestamp"]
    }
  },
  "firestore": {
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Chat history for the AI assistant"
    },
    "/contactSubmissions/{submissionId}": {
      "schema": "ContactSubmission",
      "description": "Submissions from the contact form"
    }
  }
}
